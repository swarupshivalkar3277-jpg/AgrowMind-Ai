MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=agromind_ai
# Optional: use public resolvers when mongodb+srv DNS lookup fails locally/hosted.
MONGO_DNS_NAMESERVERS=1.1.1.1,8.8.8.8
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
FRONTEND_ORIGIN=http://localhost:5173

RESEND_API_KEY=
EMAIL_FROM=AgroMind AI <otp@your-verified-domain.com>
# Development only: if Resend rejects delivery while you are testing locally,
# log the OTP in the backend console so registration/login can still be tested.
# Never enable this in production.
EMAIL_OTP_DEV_FALLBACK=false

# Optional deployment model hosting. If model files are not committed into
# backend/training, set either MODEL_BASE_URL or per-crop URLs on Render.
# MODEL_BASE_URL=https://example.com/agromind-models
# TOMATO_MODEL_URL=https://example.com/tomato_model.keras
# MANGO_MODEL_URL=https://example.com/mango_model.keras
# COCONUT_MODEL_URL=https://example.com/coconut_model.keras
